@model IEnumerable<Backend_Search_Fakebook.Models.Object>

<div class="container mt-5">

    @* ==========================================
       PHẦN 1: KHU VỰC TÌM KIẾM (Căn giữa, to, rõ ràng) 
       ========================================== *@
    <div class="row justify-content-center mb-5">
        <div class="col-md-8 text-center">
            <h1 class="display-5 text-primary fw-bold mb-4">Fakebook Search</h1>

            <form method="get" action="/Home/Index" class="shadow-sm rounded">
                <div class="input-group input-group-lg">
                    <input type="text" name="tuKhoa" value="@ViewBag.TuKhoaDaNhap" class="form-control border-primary" placeholder="Bạn muốn tìm ai, nhóm nào...?" />
                    <button class="btn btn-primary px-4" type="submit">
                        🔍 Tìm kiếm
                    </button>
                </div>
            </form>

            <div class="mt-3">
                <a href="/Home/TestTachTu" target="_blank" class="text-muted text-decoration-none small">
                    ⚙️ Chạy thử Cỗ máy tách từ (API)
                </a>
            </div>
        </div>
    </div>

    @* ==========================================
       PHẦN 2: KHU VỰC HIỂN THỊ KẾT QUẢ
       ========================================== *@
    <div class="row justify-content-center">
        <div class="col-md-8">

            @* Kiểm tra xem Model có dữ liệu không *@
            @if (Model != null && Model.Any())
            {
                <p class="text-muted mb-3">Tìm thấy <b>@Model.Count()</b> kết quả phù hợp cho từ khóa "@ViewBag.TuKhoaDaNhap"</p>

                @* Vòng lặp vẽ từng Thẻ (Card) thay vì vẽ Bảng (Table) *@
                foreach (var item in Model)
                {
                    <div class="card mb-3 shadow-sm border-0">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h4 class="card-title text-dark mb-1">
                                        @if (item.Type == "USER")
                                        {
                                            <span>👤 Tài khoản cá nhân</span>
                                        }
                                        else if (item.Type == "GROUP")
                                        {

                                            <span>👥 Nhóm cộng đồng</span>
                                        }
                                        else
                                        {

                                            <span>📄 Bài viết</span>
                                        }
                                    </h4>
                                    <p class="text-muted small mb-0">Hệ thống ID: #@item.Id</p>
                                </div>
                                <div class="text-end">
                                    <span class="badge bg-primary rounded-pill px-3 py-2 mb-1">Điểm nổi tiếng: @item.SortKey</span>
                                </div>
                            </div>

                            <hr class="text-muted my-2" />

                            <div class="mt-2">
                                <span class="text-muted small me-2">Từ khóa Index:</span>
                                @foreach (var token in item.Tokens)
                                {
                                    <span class="badge bg-light text-dark border me-1">@token.TokenText</span>
                                }
                            </div>
                        </div>
                    </div>
                }
            }
            else if (!string.IsNullOrEmpty(ViewBag.TuKhoaDaNhap))
            {
                @* Giao diện khi TÌM KHÔNG THẤY AI *@
                <div class="alert alert-secondary text-center p-5 shadow-sm border-0" role="alert">
                    <h1 class="display-4 text-muted">🕵️‍♂️</h1>
                    <h4 class="alert-heading mt-3">Rất tiếc!</h4>
                    <p class="mb-0">Chúng tôi không tìm thấy kết quả nào cho từ khóa <b>"@ViewBag.TuKhoaDaNhap"</b>.</p>
                    <p class="text-muted small">Hãy thử tìm bằng một từ khóa ngắn hơn hoặc kiểm tra lại chính tả nhé.</p>
                </div>
            }

        </div>
    </div>
</div>